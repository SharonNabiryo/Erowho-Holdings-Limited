# ── Database ──────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/erowho"

# ── Authentication ────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-minimum-32-chars-change-in-production"

# ── Anthropic AI ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-your-key-here"

# ── Google Maps ───────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY="your-google-maps-key"
GOOGLE_MAPS_SERVER_KEY="your-server-side-maps-key"

# ── Google Calendar (Appointments) ───────────────────────────
GOOGLE_CALENDAR_CLIENT_ID="your-google-oauth-client-id"
GOOGLE_CALENDAR_CLIENT_SECRET="your-google-oauth-client-secret"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/auth/callback/google"

# ── Email (Resend - recommended) ─────────────────────────────
RESEND_API_KEY="re_your_resend_key"
EMAIL_FROM="noreply@erowho.com"
AGENT_NOTIFICATION_EMAIL="leads@erowho.com"

# ── Real Estate Data APIs ─────────────────────────────────────
# ATTOM Property Data
ATTOM_API_KEY="your-attom-api-key"
ATTOM_BASE_URL="https://api.gateway.attomdata.com"

# RentCast (Rental Market Data)
RENTCAST_API_KEY="your-rentcast-api-key"
RENTCAST_BASE_URL="https://api.rentcast.io/v1"

# MLS / IDX Integration
IDX_BROKER_KEY="your-idx-broker-key"
IDX_BROKER_URL="https://api.idxbroker.com"
CREA_API_KEY="your-crea-key"
CREA_BASE_URL="https://api.crea.ca"

# ── Storage (Cloudflare R2 / AWS S3) ─────────────────────────
S3_ACCESS_KEY="your-s3-access-key"
S3_SECRET_KEY="your-s3-secret-key"
S3_BUCKET_NAME="erowho-assets"
S3_REGION="us-east-1"
S3_ENDPOINT="https://your-r2-endpoint.r2.cloudflarestorage.com"
NEXT_PUBLIC_CDN_URL="https://cdn.erowho.com"

# ── Analytics ─────────────────────────────────────────────────
NEXT_PUBLIC_GA_ID="G-XXXXXXXXXX"
NEXT_PUBLIC_GTM_ID="GTM-XXXXXXX"
POSTHOG_KEY="your-posthog-key"
POSTHOG_HOST="https://app.posthog.com"

# ── Webhooks & Integrations ───────────────────────────────────
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/xxx"
ZAPIER_WEBHOOK_URL="https://hooks.zapier.com/xxx"

# ── App Config ────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://erowho.com"
NEXT_PUBLIC_APP_NAME="Erowho Holdings"
NODE_ENV="development"
